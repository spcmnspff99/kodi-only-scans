# ── SMB / NAS connection ─────────────────────────────────────────────────────
SMB_HOST=192.168.1.10
SMB_USER=kodiuser
SMB_PASS=s3cret
SMB_PORT=445

# ── SMB share configuration ───────────────────────────────────────────────────
# Option A – single share for both libraries
#   Set SMB_SHARE and use SMB_MOVIES_PATH / SMB_TV_PATH to point at
#   sub-folders within that share.
#
# Option B – separate share per library
#   Set SMB_MOVIES_SHARE and/or SMB_TV_SHARE to override SMB_SHARE for that
#   library.  If a library lives at the root of its own dedicated share, leave
#   the corresponding *_PATH variable empty (or omit it entirely).

# Fallback share used for any library that does not have its own *_SHARE set.
SMB_SHARE=media

# Per-library share overrides (comment out to fall back to SMB_SHARE above)
#SMB_MOVIES_SHARE=movies
#SMB_TV_SHARE=tv

# Path inside the share where the library root folder lives.
# Leave empty (or omit) when the library root IS the share root.
SMB_MOVIES_PATH=Movies
SMB_TV_PATH=TV

# ── MariaDB / Kodi database ───────────────────────────────────────────────────
DB_HOST=192.168.1.20
DB_PORT=3306
DB_USER=kodi
DB_PASS=kodipass
DB_NAME=MyVideos131

# ── Scheduler ────────────────────────────────────────────────────────────────
# Standard 5-field cron expression (minute hour dom month dow)
# Default: daily at 04:00 UTC
SCAN_CRON=0 4 * * *

# ── Internal ─────────────────────────────────────────────────────────────────
# Path inside the container where the SQLite history DB is stored
HISTORY_DB=/data/scan_history.db
